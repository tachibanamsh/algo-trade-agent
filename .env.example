# ─────────────────────────────────────────────
#  algo-trade-agent 設定ファイル
#  このファイルを .env にコピーして値を埋めてください
#  $ cp .env.example .env
# ─────────────────────────────────────────────

# OpenD接続先（通常デフォルトのままでOK）
MOOMOO_OPEND_HOST=127.0.0.1
MOOMOO_OPEND_PORT=11111

# 証券会社リージョン
#   日本法人 (Futu Securities Japan): FUTUSECURITIES
#   シンガポール法人:                  FUTUSG
#   米国法人:                          FUTUINC
MOOMOO_SECURITY_FIRM=FUTUSECURITIES

# 取引環境: SIMULATE（ペーパートレード）または REAL（本番）
MOOMOO_TRD_ENV=SIMULATE

# 取引パスワード（REAL口座のみ必須）
MOOMOO_TRADE_PASSWORD=

# ショート売り: 1=有効（借株権限が必要）、0=ロングのみ
MOOMOO_ALLOW_SHORT=0

# アカウントID（手動指定）
# 自動検出に失敗する場合（日本口座など）は直接指定してください
# moomooアプリ → 取引 → 右上メニュー → アカウント情報 で確認
# MOOMOO_ACC_ID=

# 1回あたりの運用金額（JPY）
# 省略時は口座現金の80%を自動使用
# MOOMOO_NOTIONAL_JPY=500000
